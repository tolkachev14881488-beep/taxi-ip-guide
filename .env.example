# Database (optional on Vercel — demo mode works without DB)
DATABASE_URL="file:./dev.db"

# Demo mode: auto-enabled when bePaid keys are missing
DEMO_MODE=true
DEMO_SECRET=change-me-to-random-string

# bePaid payment gateway (leave empty for demo)
BEPAID_SHOP_ID=
BEPAID_SECRET_KEY=
BEPAID_TEST_MODE=true

# Product
PRODUCT_PRICE_BYN=49

# Site URL (must be HTTPS in production for webhooks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
